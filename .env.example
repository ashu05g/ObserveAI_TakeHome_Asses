# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_CALLERS_TABLE=callers
AIRTABLE_INTERACTIONS_TABLE=interactions

# OpenAI
OPENAI_API_KEY=

# Langfuse (set LANGFUSE_ENABLED=false to disable tracing locally)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
# LANGFUSE_ENABLED=true

# Resend (post-call alert emails)
RESEND_API_KEY=
ALERT_EMAIL_FROM=onboarding@resend.dev
ALERT_EMAIL_TO=

# VAPI webhook — shared secret, must match the X-VAPI-Secret custom header
# configured in the VAPI dashboard → Assistant → Server URL.
VAPI_WEBHOOK_SECRET=

# VAPI programmatic management (only needed when running scripts/vapi_sync.py)
VAPI_API_KEY=
SERVER_URL=https://your-railway-app.up.railway.app
